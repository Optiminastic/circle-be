# ─────────────────────────────────────────────────────────────────────────────
# circle-be PRODUCTION env (Hetzner VPS + Docker Compose).
# Copy to `.env` on the server and fill in real values. NEVER commit the real
# .env — only this placeholder template is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres runs on the VPS (the `db` compose service). Use the SAME password in
# POSTGRES_PASSWORD and inside DATABASE_URL. Data is migrated in from Neon once
# (see DEPLOY.md).
POSTGRES_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=postgresql+psycopg://circle:change-me-to-a-strong-password@db:5432/circle
AUTO_CREATE_TABLES=true

# The Docker network avora's Caddy is on (so it can reach circle-be-api by name).
# Verify with:  docker inspect deploy-caddy-1 -f '{{range $k,$_ := .NetworkSettings.Networks}}{{$k}}{{end}}'
PROXY_NETWORK=deploy_default

# Allowed browser origin = the Vercel-hosted frontend. Required in production.
CORS_ORIGINS=https://circle.optiminastic.com
FRONTEND_URL=https://circle.optiminastic.com

LOG_LEVEL=INFO

# ── Object storage (Backblaze B2 / S3) — copy from the Render dashboard ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=
# AWS_S3_ENDPOINT=        # only for non-AWS S3-compatible providers (B2/MinIO)
# AWS_S3_PREFIX=
MAX_UPLOAD_MB=15

# ── Email: Gmail SMTP as careers@optiminastic.com (leave the HTTP-API keys blank
#    so the plain-SMTP transport is used). Outbound 587 is allowed on Hetzner. ──
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=careers@optiminastic.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=careers@optiminastic.com
SMTP_FROM_NAME=Optiminastic HR Team
SMTP_REPLY_TO=careers@optiminastic.com
HR_CC_EMAIL=careers@optiminastic.com

# ── Google Calendar OAuth — copy client id/secret from the Render dashboard ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.circle.optiminastic.com/api/calendar/oauth/callback
GOOGLE_CALENDAR_ID=primary

# Optional: token-gated candidate handoff feed (blank = disabled / 404).
CANDIDATE_FEED_TOKEN=
