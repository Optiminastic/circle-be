# Copy to .env and fill in your PostgreSQL connection string.
# Accepts postgresql://  or  postgresql+psycopg://  (postgres:// is also normalized).
DATABASE_URL=postgresql://user:password@localhost:5432/curcle

# Create the resource tables (id TEXT PK, data JSONB) if they don't exist.
# Set to false if your database schema is managed elsewhere.
AUTO_CREATE_TABLES=true

# Comma-separated list of allowed browser origins (the frontend).
# REQUIRED in production: include the deployed frontend domain(s), or the browser
# blocks API calls (the usual "frontend can't reach backend in prod" cause).
# localhost + private-LAN origins are always allowed via a built-in regex.
# Prod example: CORS_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

LOG_LEVEL=INFO

# Backblaze B2 (S3-compatible) document storage. Leave blank to disable uploads.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_BUCKET=curcle-documents
MAX_UPLOAD_MB=15

# Email. Three transports, tried in this order (first one configured wins):
#  1) Resend HTTP API — set RESEND_API_KEY, OR just point the SMTP creds at Resend
#     (SMTP_HOST=smtp.resend.com, SMTP_USER=resend, SMTP_PASSWORD=re_...) and the
#     key is derived automatically. Works on hosts that block outbound SMTP (e.g.
#     Render free tier). Verify your domain at resend.com/domains first.
#  2) SendGrid HTTP API — set SENDGRID_API_KEY + a SendGrid-verified SMTP_FROM_EMAIL.
#  3) Plain SMTP (Gmail/Workspace app password, etc.) — used when no HTTP API key
#     is configured. NOTE: outbound SMTP is blocked on Render free tier — use
#     Resend/SendGrid there.
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Optiminastic
# Optional Reply-To (where candidate replies land); falls back to the From address.
SMTP_REPLY_TO=hr@optiminastic.com

# Google Calendar sync (single shared HR account, one-way push). Leave blank to
# disable — scheduling still works, events just won't be pushed.
# Create a Google Cloud project, enable the Google Calendar API, configure the
# OAuth consent screen, and create an OAuth 2.0 "Web application" client whose
# Authorized redirect URI is the GOOGLE_REDIRECT_URI below. Then connect the
# shared account once from the in-app Settings page.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/oauth/callback
GOOGLE_CALENDAR_ID=primary
FRONTEND_URL=http://localhost:3001

# Shared secret that gates the PUBLIC careers endpoints (/api/public/* — OTP,
# applied-check, apply). The careers server (Next.js server actions) sends it as
# the X-Internal-Token header; a browser fetch or copied cURL can't know it, so
# direct calls are rejected with 403. Generate with: python -c "import secrets;
# print(secrets.token_hex(32))" and set the SAME value as the careers server's
# INTERNAL_API_TOKEN. Leave blank to DISABLE the gate (not recommended in prod).
INTERNAL_API_TOKEN=
