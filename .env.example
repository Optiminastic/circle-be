# Copy to .env and fill in your PostgreSQL connection string.
# Accepts postgresql://  or  postgresql+psycopg://  (postgres:// is also normalized).
DATABASE_URL=postgresql://user:password@localhost:5432/curcle

# Create the resource tables (id TEXT PK, data JSONB) if they don't exist.
# Set to false if your database schema is managed elsewhere.
AUTO_CREATE_TABLES=true

# Comma-separated list of allowed CORS origins (the frontend).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

LOG_LEVEL=INFO

# Backblaze B2 (S3-compatible) document storage. Leave blank to disable uploads.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_BUCKET=curcle-documents
MAX_UPLOAD_MB=15
